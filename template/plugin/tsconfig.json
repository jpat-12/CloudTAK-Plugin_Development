{
    "compilerOptions": {
        "target":              "ES2022",
        "module":              "ESNext",
        "moduleResolution":    "Bundler",
        "strict":              true,
        "jsx":                 "preserve",
        "jsxImportSource":     "vue",
        "skipLibCheck":        true,
        "resolveJsonModule":   true,
        "isolatedModules":     true,
        "allowImportingTsExtensions": true,
        "noEmit":              true
    },
    "include": ["**/*.ts", "**/*.vue"],
    "exclude": ["node_modules"]
}
